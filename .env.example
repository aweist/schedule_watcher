# API Configuration
API_INSTANCE=your-wix-instance-id
API_COMP_ID=your-component-id

# Team Configuration (e.g., "Jeff", "Cory G", "Rachel Wise", etc.)
TEAM_NAME=Your Team Captain Name

# Email Configuration
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com

# Schedule Configuration
POLL_INTERVAL=5m

# Web Debug Interface
WEB_ENABLED=true
WEB_PORT=8080

# Timezone
TZ=America/Denver

# Optional: Database path (defaults to ./schedule.db, compose sets /data/schedule.db)
# DB_PATH=/data/schedule.db